{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-apps-tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "违规软件检测工具",
  "version": "0.1.0",
  "identifier": "com.violation-scanner.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "违规软件内容检测器",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
